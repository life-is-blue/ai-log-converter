#!/usr/bin/env bash
set -euo pipefail

DEFAULT_URL="https://mcp.100100086.xyz"
GIT_LIBRARY_URL="${GIT_LIBRARY_URL:-$DEFAULT_URL}"

# Cache configuration
CACHE_DIR="${GIT_LIBRARY_CACHE:-$HOME/.cache/git-library}"
LIBRARIES_TTL_DAYS_RAW="${GIT_LIBRARY_LIBRARIES_TTL_DAYS:-1}"
if [[ "$LIBRARIES_TTL_DAYS_RAW" =~ ^[0-9]+$ ]]; then
  LIBRARIES_TTL_DAYS="$LIBRARIES_TTL_DAYS_RAW"
else
  LIBRARIES_TTL_DAYS="1"
fi
LIBRARIES_TTL_SECONDS=$((LIBRARIES_TTL_DAYS * 86400))
CLI_AMBIGUITY_MARGIN_RAW="${GIT_LIBRARY_CLI_AMBIGUITY_MARGIN:-0.12}"
if [[ "$CLI_AMBIGUITY_MARGIN_RAW" =~ ^(0(\.[0-9]+)?|1(\.0+)?)$ ]]; then
  CLI_AMBIGUITY_MARGIN="$CLI_AMBIGUITY_MARGIN_RAW"
else
  CLI_AMBIGUITY_MARGIN="0.12"
fi

has_cmd() {
  command -v "$1" >/dev/null 2>&1
}

usage() {
  cat <<'USAGE'
search-docs: lightweight CLI for git-library HTTP API

Usage:
  search-docs health [--url URL]
  search-docs libraries [--refresh] [--fresh-for-query QUERY] [--url URL]
  search-docs search <query...> [--library LIB_ID] [--limit N] [--offset N] [--fields CSV] [--catalog-mode topic|full|none] [--url URL]
  search-docs read <LIB_ID/PATH | LIB_ID PATH> [--url URL]
  search-docs manifest <LIB_ID> [--url URL]
  search-docs recent [--library LIB_ID] [--days N] [--url URL]

Notes:
  - 'health' returns remote status and local dependency checks.
  - 'libraries' caches by endpoint URL (default TTL: 1 day).
  - use --refresh to force update; use --fresh-for-query for freshness-sensitive questions.
  - 'search' may add presentation-only cli_hint when jq is available.

Environment:
  GIT_LIBRARY_CACHE        Cache directory (default: ~/.cache/git-library)
  GIT_LIBRARY_LIBRARIES_TTL_DAYS  Libraries cache TTL in days (default: 1)

Examples:
  search-docs libraries
  search-docs libraries --refresh
  search-docs libraries --fresh-for-query "最新发布的命令"
  search-docs search "GitHub Actions migrate to CNB" --library cnb-feedback
  search-docs search --library gemini-cli -- "--output-format jsonl stream"
  search-docs read openai-codex docs/cli-reference.md
  search-docs manifest claude-code
  search-docs recent --library openai-codex --days 3
USAGE
}

require_arg() {
  local flag="$1"
  local value="${2:-}"
  if [[ -z "$value" ]]; then
    echo "Missing value for $flag" >&2
    exit 1
  fi
}

pretty_json() {
  if has_cmd jq; then
    jq .
  else
    cat
  fi
}

url_encode_path() {
  local raw="$1"

  if has_cmd python3; then
    python3 - "$raw" <<'PY'
import sys, urllib.parse
print(urllib.parse.quote(sys.argv[1], safe="/"))
PY
    return
  fi

  if has_cmd jq; then
    # jq @uri encodes '/' as %2F; restore it for path segments.
    printf '%s' "$raw" | jq -sRr @uri | sed 's/%2F/\//g'
    return
  fi

  echo "read requires python3 or jq for URL encoding." >&2
  exit 1
}

curl_json() {
  if ! has_cmd curl; then
    echo "Missing dependency: curl (required)." >&2
    exit 1
  fi
  curl -fsS "$@"
}

emit_health() {
  local url="$1"
  local curl_present=false
  local python_present=false
  local jq_present=false

  has_cmd curl && curl_present=true
  has_cmd python3 && python_present=true
  has_cmd jq && jq_present=true

  if [[ "$curl_present" != true ]]; then
    echo "Missing dependency: curl (required)." >&2
    exit 1
  fi

  local remote_json
  remote_json="$(curl_json "${url%/}/health")"

  if [[ "$jq_present" == true ]]; then
    jq -n \
      --argjson remote "$remote_json" \
      --argjson curl_present "$curl_present" \
      --argjson python_present "$python_present" \
      --argjson jq_present "$jq_present" \
      '
      ($remote + {
        local: {
          dependencies: {
            curl: $curl_present,
            python3: $python_present,
            jq: $jq_present
          },
          notes: [
            (if ($python_present | not) then "python3 missing: read uses jq URL-encoding fallback" else empty end)
          ]
        }
      })
      '
    return
  fi

  if [[ "$python_present" != true ]]; then
    echo "warning: read requires python3 or jq for URL encoding." >&2
  fi
  echo "warning: jq not found; health output only includes remote status." >&2
  printf '%s\n' "$remote_json"
}

# Build per-endpoint cache key to avoid cross-endpoint cache pollution.
cache_key_for_url() {
  local url="$1"
  if has_cmd shasum; then
    printf '%s' "$url" | shasum -a 256 | awk '{print $1}'
    return
  fi
  if has_cmd md5sum; then
    printf '%s' "$url" | md5sum | awk '{print $1}'
    return
  fi
  if has_cmd md5; then
    md5 -q -s "$url"
    return
  fi
  printf '%s' "$url" | cksum | awk '{print $1}'
}

libraries_cache_file() {
  local url="$1"
  local key
  key="$(cache_key_for_url "${url%/}")"
  printf '%s/libraries-%s.json' "$CACHE_DIR" "$key"
}

is_freshness_query() {
  local raw="$1"
  local q
  q="$(printf '%s' "$raw" | tr '[:upper:]' '[:lower:]')"
  case "$q" in
    *latest*|*new\ feature*|*recent*|*release*|*changelog*|*release\ note*|*what\'s\ new*|*最新*|*新功能*|*刚发布*|*最近更新*)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

# Check if cached libraries data is fresh (within TTL)
is_cache_fresh() {
  local cache_file="$1"
  [[ -f "$cache_file" ]] || return 1

  local now epoch mtime age
  now=$(date +%s)

  # Get file modification time (compatible with macOS and Linux)
  if has_cmd stat; then
    if [[ "$(uname)" == "Darwin" ]]; then
      mtime=$(stat -f %m "$cache_file" 2>/dev/null) || return 1
    else
      mtime=$(stat -c %Y "$cache_file" 2>/dev/null) || return 1
    fi
  else
    return 1
  fi

  age=$((now - mtime))
  [[ $age -lt $LIBRARIES_TTL_SECONDS ]]
}

# Fetch libraries with cache support
emit_libraries() {
  local url="$1"
  local force_refresh="${2:-false}"
  local fresh_for_query="${3:-}"
  local cache_file
  cache_file="$(libraries_cache_file "$url")"

  if [[ -n "$fresh_for_query" ]] && is_freshness_query "$fresh_for_query"; then
    force_refresh=true
  fi

  # Ensure cache directory exists
  mkdir -p "$CACHE_DIR" 2>/dev/null || true

  # Check if we can use cached data
  if [[ "$force_refresh" != true ]] && is_cache_fresh "$cache_file"; then
    cat "$cache_file"
    return
  fi

  # Fetch fresh data
  local fresh_json
  if fresh_json="$(curl_json "${url%/}/api/libraries")"; then
    # Update cache (best effort)
    printf '%s\n' "$fresh_json" > "$cache_file" 2>/dev/null || true
    printf '%s\n' "$fresh_json"
    return
  fi

  if [[ -f "$cache_file" ]]; then
    echo "warning: libraries fetch failed, falling back to stale cache for ${url%/}" >&2
    cat "$cache_file"
    return
  fi

  echo "libraries fetch failed and no cache is available for ${url%/}" >&2
  return 1
}

if [[ $# -lt 1 ]]; then
  usage
  exit 1
fi

cmd="$1"
shift

case "$cmd" in
  -h|--help|help)
    usage
    ;;

  health)
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --url)
          require_arg "$1" "${2:-}"
          GIT_LIBRARY_URL="$2"
          shift 2
          ;;
        *)
          echo "Unknown option for health: $1" >&2
          exit 1
          ;;
      esac
    done
    emit_health "$GIT_LIBRARY_URL" | pretty_json
    ;;

  libraries)
    force_refresh=false
    fresh_for_query=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --url)
          require_arg "$1" "${2:-}"
          GIT_LIBRARY_URL="$2"
          shift 2
          ;;
        --refresh)
          force_refresh=true
          shift
          ;;
        --fresh-for-query)
          require_arg "$1" "${2:-}"
          fresh_for_query="$2"
          shift 2
          ;;
        *)
          echo "Unknown option for libraries: $1" >&2
          exit 1
          ;;
      esac
    done
    emit_libraries "$GIT_LIBRARY_URL" "$force_refresh" "$fresh_for_query" | pretty_json
    ;;

  search)
    library=""
    limit="8"
    offset=""
    fields=""
    catalog_mode=""
    query_parts=()
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --)
          shift
          while [[ $# -gt 0 ]]; do
            query_parts+=("$1")
            shift
          done
          break
          ;;
        --library|-l)
          require_arg "$1" "${2:-}"
          library="$2"
          shift 2
          ;;
        --limit)
          require_arg "$1" "${2:-}"
          limit="$2"
          shift 2
          ;;
        --offset)
          require_arg "$1" "${2:-}"
          offset="$2"
          shift 2
          ;;
        --fields)
          require_arg "$1" "${2:-}"
          fields="$2"
          shift 2
          ;;
        --catalog-mode)
          require_arg "$1" "${2:-}"
          catalog_mode="$2"
          shift 2
          ;;
        --url)
          require_arg "$1" "${2:-}"
          GIT_LIBRARY_URL="$2"
          shift 2
          ;;
        -*)
          echo "Unknown option for search: $1" >&2
          exit 1
          ;;
        *)
          query_parts+=("$1")
          shift
          ;;
      esac
    done

    if [[ ${#query_parts[@]} -eq 0 ]]; then
      echo "search requires a query string." >&2
      exit 1
    fi
    query="${query_parts[*]}"

    curl_args=(
      --get
      "${GIT_LIBRARY_URL%/}/api/search"
      --data-urlencode "q=$query"
      --data "limit=$limit"
    )
    if [[ -n "$library" ]]; then
      curl_args+=(--data-urlencode "library=$library")
    fi
    if [[ -n "$offset" ]]; then
      curl_args+=(--data "offset=$offset")
    fi
    if [[ -n "$fields" ]]; then
      curl_args+=(--data-urlencode "fields=$fields")
    fi
    if [[ -n "$catalog_mode" ]]; then
      curl_args+=(--data-urlencode "catalog_mode=$catalog_mode")
    fi

    response_json="$(curl_json "${curl_args[@]}")"

    if has_cmd jq; then
      if [[ -n "$library" ]]; then
        response_json="$(printf '%s' "$response_json" | jq --arg library "$library" --argjson ambiguity_margin "$CLI_AMBIGUITY_MARGIN" '
          . + {
            cli_hint_source: "presentation_only",
            cli_hint: (
              if ((.total // 0) == 0) then
                "No hits in \($library); try cross-library search by removing --library."
              elif ((.results | length) >= 2 and ((((.results[0].display_score // 1) - (.results[1].display_score // 1)) | if . < 0 then - . else . end) <= $ambiguity_margin)) then
                "Top results are close; if this is interactive, ask one clarification before read."
              else
                "Primary-library search has candidates; treat ranking as preview and verify with read_document."
              end
            )
          }
        ')"
      else
        response_json="$(printf '%s' "$response_json" | jq --argjson ambiguity_margin "$CLI_AMBIGUITY_MARGIN" '
          . + {
            cli_hint_source: "presentation_only",
            cli_hint: (
              if ((.total // 0) == 0) then
                "No hits; try a shorter query or force a target library with --library."
              elif ((.results | length) >= 2 and ((.results[0].library_id // "") != (.results[1].library_id // "")) and ((((.results[0].display_score // 1) - (.results[1].display_score // 1)) | if . < 0 then - . else . end) <= $ambiguity_margin)) then
                "Top libraries are close; return Top1+Top2 and ask clarification in interactive mode."
              else
                "Cross-library results look usable; read top candidates before final answer."
              end
            )
          }
        ')"
      fi
    fi

    printf '%s\n' "$response_json" | pretty_json
    ;;

  read)
    url="${GIT_LIBRARY_URL%/}"
    positional=()
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --url)
          require_arg "$1" "${2:-}"
          url="${2%/}"
          shift 2
          ;;
        -*)
          echo "Unknown option for read: $1" >&2
          exit 1
          ;;
        *)
          positional+=("$1")
          shift
          ;;
      esac
    done

    lib=""
    path=""
    if [[ ${#positional[@]} -eq 1 ]]; then
      target="${positional[0]}"
      if [[ "$target" != */* ]]; then
        echo "read expects LIB_ID/PATH or LIB_ID PATH" >&2
        exit 1
      fi
      lib="${target%%/*}"
      path="${target#*/}"
    elif [[ ${#positional[@]} -ge 2 ]]; then
      lib="${positional[0]}"
      path="${positional[1]}"
    else
      echo "read expects LIB_ID/PATH or LIB_ID PATH" >&2
      exit 1
    fi

    enc_path="$(url_encode_path "$path")"
    curl_json "$url/api/read/$lib/$enc_path"
    ;;

  manifest)
    lib=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --url)
          require_arg "$1" "${2:-}"
          GIT_LIBRARY_URL="$2"
          shift 2
          ;;
        -*)
          echo "Unknown option for manifest: $1" >&2
          exit 1
          ;;
        *)
          if [[ -z "$lib" ]]; then
            lib="$1"
          else
            echo "Too many arguments for manifest" >&2
            exit 1
          fi
          shift
          ;;
      esac
    done

    if [[ -z "$lib" ]]; then
      echo "manifest requires a library ID." >&2
      exit 1
    fi

    curl_json "${GIT_LIBRARY_URL%/}/api/manifest/$lib" | pretty_json
    ;;

  recent)
    library=""
    days="7"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --library|-l)
          require_arg "$1" "${2:-}"
          library="$2"
          shift 2
          ;;
        --days)
          require_arg "$1" "${2:-}"
          days="$2"
          shift 2
          ;;
        --url)
          require_arg "$1" "${2:-}"
          GIT_LIBRARY_URL="$2"
          shift 2
          ;;
        *)
          echo "Unknown option for recent: $1" >&2
          exit 1
          ;;
      esac
    done

    endpoint="${GIT_LIBRARY_URL%/}/api/recent?days=$days"
    if [[ -n "$library" ]]; then
      endpoint="${GIT_LIBRARY_URL%/}/api/recent?library=$library&days=$days"
    fi
    curl_json "$endpoint" | pretty_json
    ;;

  *)
    echo "Unknown command: $cmd" >&2
    usage
    exit 1
    ;;
esac
